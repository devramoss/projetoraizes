{
  "info": {
    "name": "RaizesNordeste.postman_collection",
    "description": "Coleção Postman para API Raízes do Nordeste — endpoints principais: auth, usuarios, produtos, pedidos, pagamentos (mock) e fidelidade. Variáveis: baseUrl, token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminEmail",
      "value": "admin@teste.com",
      "type": "string"
    },
    {
      "key": "adminSenha",
      "value": "admin123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Autenticação e obtenção de token JWT",
      "item": [
        {
          "name": "Login - obter token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"senha\": \"{{adminSenha}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Criar usuário (POST /usuarios)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Cliente Teste\",\n  \"email\": \"cliente@teste.com\",\n  \"senha\": \"cliente123\",\n  \"telefone\": \"31988888888\",\n  \"role\": \"CLIENTE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "usuarios"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Listar usuários (GET /usuarios)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/usuarios?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "usuarios"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Produtos",
      "item": [
        {
          "name": "Listar produtos (GET /produtos)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/produtos?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "produtos"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Criar produto (POST /produtos)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Acarajé\",\n  \"descricao\": \"Acarajé tradicional\",\n  \"preco\": 15.00,\n  \"ativo\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/produtos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "produtos"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "Criar pedido (POST /pedidos)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"canalPedido\": \"APP\",\n  \"clienteId\": 1,\n  \"unidadeId\": 1,\n  \"itens\": [\n    { \"produtoId\": 1, \"quantidade\": 2 }\n  ],\n  \"formaPagamento\": \"MOCK\",\n  \"observacao\": \"Sem cebola\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pedidos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pedidos"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Listar pedidos (GET /pedidos)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/pedidos?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pedidos"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Filtrar pedidos por canal (GET /pedidos?canalPedido=TOTEM)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/pedidos?canalPedido=TOTEM",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pedidos"
              ],
              "query": [
                {
                  "key": "canalPedido",
                  "value": "TOTEM"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pagamentos (Mock)",
      "item": [
        {
          "name": "Simular pagamento aprovado (POST /pagamentos/:pedidoId/mock)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"simular\": \"aprovado\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pagamentos/1/mock",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pagamentos",
                "1",
                "mock"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Simular pagamento recusado (POST /pagamentos/:pedidoId/mock)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"simular\": \"recusado\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pagamentos/1/mock",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pagamentos",
                "1",
                "mock"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Fidelidade",
      "item": [
        {
          "name": "Consultar pontos (GET /fidelidade/:clienteId)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/fidelidade/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fidelidade",
                "1"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Resgatar benefício (POST /fidelidade/:clienteId/resgatar)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"beneficioId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/fidelidade/1/resgatar",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "fidelidade",
                "1",
                "resgatar"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Exemplos de erros / validações",
      "item": [
        {
          "name": "Criar pedido sem canalPedido (erro 400/422)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clienteId\": 1,\n  \"unidadeId\": 1,\n  \"itens\": [ { \"produtoId\": 1, \"quantidade\": 1 } ],\n  \"formaPagamento\": \"MOCK\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pedidos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pedidos"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Acesso sem token (GET /pedidos)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/pedidos",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "pedidos"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
